# LLM API 配置
# 如果使用反代（如 CLIProxy），填写反代提供的 Key；如果使用百炼平台，填写百炼 API Key
API_KEY=your_api_key_here
# LLM API 地址（支持 OpenAI 兼容接口）
# 百炼平台: https://dashscope.aliyuncs.com/compatible-mode/v1
# 本地反代示例: http://127.0.0.1:8317/v1
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型名称
MODEL_NAME=qwen-max

# 闲鱼登录 Cookie（必填）
COOKIES_STR=your_cookies_here

# 人工接管触发关键词（卖家发送此关键词切换人工/自动模式）
TOGGLE_KEYWORDS=。

# 是否模拟人工打字延迟（True/False）
SIMULATE_HUMAN_TYPING=False
