# LLM 接入模式
# 可选值: proxy / api / qclaw / auto
# proxy: 使用本地反代
# api: 使用云端/官方 OpenAI 兼容 API
# qclaw: 使用当前仓库内置的 QClaw 交互模式
# auto: 兼容旧配置，自动判断
LLM_PROVIDER=auto

# 云端/官方 API 配置
API_KEY=your_api_key_here
API_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
API_MODEL_NAME=qwen-max

# 本地反代配置
LOCAL_PROXY_API_KEY=openclaw-local-key
LOCAL_PROXY_BASE_URL=http://127.0.0.1:8317/v1
LOCAL_PROXY_MODEL_NAME=gpt-5.3-codex

# 兼容旧版配置时使用；新配置优先走上面的分模式变量
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-max

# 闲鱼登录 Cookie（必填）
COOKIES_STR=your_cookies_here

# 人工接管触发关键词（卖家发送此关键词切换人工/自动模式）
TOGGLE_KEYWORDS=。

# 是否模拟人工打字延迟（True/False）
SIMULATE_HUMAN_TYPING=False
